inbox:
data: {
    "inbox" : [
        {
            "conversation_partner_username": username,
            "conversation_partner_id": id
            "last_message": message
       }
    ]
}

messages:
data: {
    "sender": id/username,
    "receiver": id/username,
    "messages" : [ 
        {
            "sender": id/username,
            "receiver": id/username,
            "message": ""
        }, ... 
    ]
}

sql:
SELECT 
    LEAST(sender_id, recipient_id) AS user1, //sort lowest id
    GREATEST(sender_id, recipient_id) AS user2, //sort highest id
    message,
    created_at
FROM messages m1
WHERE created_at = (
    SELECT MAX(created_at) //max sorts lexically the highest (if alphabet z-a, date latest, number highest)
    FROM messages m2 
    WHERE LEAST(m1.sender_id, m1.recipient_id) = LEAST(m2.sender_id, m2.recipient_id) //double checks the same id from first table
      AND GREATEST(m1.sender_id, m1.recipient_id) = GREATEST(m2.sender_id, m2.recipient_id) //double checks the same id from the first table
)
AND (m1.sender_id = 5 OR m1.recipient_id = 5) //checks for which id /auth logged in
ORDER BY created_at DESC;